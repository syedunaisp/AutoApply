# ── Dashboard Environment Variables ────────────────────────────────────────
# Copy this file to .env.local for local development.
# For Cloudflare Pages deployment, set these in the Pages dashboard or via:
#   wrangler pages secret put VARIABLE_NAME --project-name your-project

# URL of your deployed Cloudflare Worker.
# For local dev, use http://localhost:8787 (wrangler dev)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Password for the dashboard login page.
# Choose a strong password — this is the only thing protecting the dashboard.
NEXT_PUBLIC_DASHBOARD_PASSWORD=change-me-to-a-strong-password

# The D1 user ID to load/save profile for.
# Create a user row in the users table first (see README for seed command).
NEXT_PUBLIC_USER_ID=your-user-id-here
