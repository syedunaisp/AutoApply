# ── Scraper Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before running the scraper.

# Shared secret between this scraper and the Cloudflare Worker.
# Must match WORKER_INGEST_KEY set via `wrangler secret put WORKER_INGEST_KEY`.
# Generate a strong random value: openssl rand -hex 32
API_KEY=your-scraper-api-key-here

# Your deployed Cloudflare Worker URL.
# Example: https://autoapply-worker.your-account.workers.dev
WORKER_URL=https://your-worker.workers.dev

# Ingest key for the /ingest-jobs endpoint on the worker.
# Must match the WORKER_INGEST_KEY Cloudflare secret.
WORKER_INGEST_KEY=your-ingest-key-here

# Comma-separated job titles to scrape each day.
# The scraper will run one search per term.
SEARCH_TERMS=ML Engineer,MLOps Engineer,Data Scientist

# Location for all searches.
SEARCH_LOCATION=India

# Specific ATS boards to query directly (guaranteed real ATS URLs).
# Format: platform:board_token,platform:board_token,...
# Defaults to a curated list of tech companies if not set.
# ATS_BOARDS=greenhouse:databricks,greenhouse:stripe,ashby:linear,ashby:cohere
